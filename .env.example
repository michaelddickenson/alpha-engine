# Alpha Engine — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit your actual .env file.

# ── Web App Auth ──────────────────────────────────────────────────────────
# Username and password for the web dashboard (HTTP Basic Auth)
AE_WEB_USER=alpha
AE_WEB_PASS=change-me

# ── Database ──────────────────────────────────────────────────────────────
# Absolute path to the SQLite database file.
# Defaults to <project_root>/data/portfolio.db if not set.
# DB_PATH=/home/youruser/alpha_engine/data/portfolio.db

# ── Email (optional — for biweekly trade plan delivery) ──────────────────
# Gmail SMTP app password (not your login password).
# See: https://support.google.com/accounts/answer/185833
SMTP_USER=your.email@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
EMAIL_TO=your.email@gmail.com
EMAIL_FROM=your.email@gmail.com

# ── DuckDNS (optional — for public HTTPS via free dynamic DNS) ───────────
# DUCKDNS_DOMAIN=yoursubdomain
# DUCKDNS_TOKEN=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Deployment ────────────────────────────────────────────────────────────
# Public URL of your instance (used in email footers)
WEB_URL=https://yoursubdomain.duckdns.org/

# ── Strategy Configuration ────────────────────────────────────────────────
# Anchor date for the biweekly rebalance schedule. Must be a Friday.
# Rebalances occur every other Friday counted from this anchor.
# FIRST_REBALANCE_DATE=YYYY-MM-DD
